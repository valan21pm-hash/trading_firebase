# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# API Keys per Broker (Scegli quale utilizzare)

# Alpaca (Consigliato per Azioni/ETF - Zero deposito, azioni frazionate)
ALPACA_API_KEY="la_tua_api_key_alpaca"
ALPACA_SECRET_KEY="il_tuo_secret_alpaca"
ALPACA_PAPER_TRADING="true" # Imposta a false per soldi veri
